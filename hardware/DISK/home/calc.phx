; 这是一个四则运算计算器

LOAD stdio

MSG "请输入第一个数:"
INP R0, INT

MSG "操作列表\n"
MSG "加法: 1\n"
MSG "减法: 2\n"
MSG "乘法: 3\n"
MSG "除法: 4\n"
MSG "请输入你的操作:"
INP R1, INT

MSG "请输入第二个数:"
INP R2, INT

LABLE add:
ADD R0, R2
LABLE_END

LABLE sub:
SUB R0, R2

LABLE_END

LABLE mul:
MUL R0,R2

LABLE_END

LABLE div:
DIV R0,R2

LABLE_END

CMP R1, 1
JZ add

CMP R1, 2
JZ sub

CMP R1, 3
JZ mul

CMP R1, 4
JZ div

POINT A, R2
MSG [A], INT